<%- include('partials/_header') %>

<main class="pt-24 pb-32 px-6 md:px-12 max-w-7xl mx-auto">
<!-- Hero Section / Title -->
<section class="mb-16 md:mb-24">
<div class="flex flex-col items-start gap-2">
<span class="font-label text-secondary text-[10px] uppercase tracking-[0.3em] font-bold">Testimonio visual</span>
<h1 class="font-headline text-5xl md:text-7xl font-light text-primary leading-tight tracking-tight">El Destello <br/><span class="italic">de lo Divino</span></h1>
<p class="max-w-md mt-6 text-on-surface-variant leading-relaxed">Instantes de gracia, desde el suave murmullo de lo íntimo, hasta la vibrante energía de la plegaria en comunidad.</p>
</div>
</section>
<!-- Category Filter (Minimalist Ghost Tabs) -->
<div class="flex flex-wrap gap-8 mb-16 items-center">
<button class="font-label text-[11px] uppercase tracking-widest border-b-2 border-secondary pb-1 text-primary font-bold">All Captures</button>
<button class="font-label text-[11px] uppercase tracking-widest border-b-2 border-transparent pb-1 text-on-surface-variant hover:text-secondary transition-colors">Servicios</button>
<button class="font-label text-[11px] uppercase tracking-widest border-b-2 border-transparent pb-1 text-on-surface-variant hover:text-secondary transition-colors">Detrás de cámaras</button>
<!-- <button class="font-label text-[11px] uppercase tracking-widest border-b-2 border-transparent pb-1 text-on-surface-variant hover:text-secondary transition-colors">Community</button> -->
</div>

<!-- LUISFER Grid -->

<main class="max-w-8xl mx-auto px-4 py-12">
    
    <div class="flex flex-wrap justify-center gap-2">
        
        <% if (fotos && fotos.length > 0) { %>
            <% fotos.forEach(foto => { %>
                <div class="w-full sm:w-[calc(50%-1.5rem)] lg:w-[calc(33.333%-1.5rem)] xl:w-[calc(25%-1.5rem)]">

                    <div class="group relative overflow-hidden bg-gray-100 shadow-sm transition-all duration-500 hover:shadow-xl">
                        <img 
                            src="/pics/<%= foto %>" 
                            alt="Momento capturado"
                            class="w-full h-80 object-cover transform transition-transform duration-700 ease-out group-hover:scale-110 "
                            loading="lazy"
                        >
                        <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-500"></div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full py-20 text-center">
                <p class="font-manrope text-gray-400 italic">No se encontraron fotografías en la carpeta.</p>
            </div>
        <% } %>

    </div>
</main>


<!-- Footer Lyric Overlay Style -->
<footer class="mt-32 relative py-32 overflow-hidden">

<p class="mt-16 font-label text-[9px] uppercase tracking-[0.4em] text-on-surface-variant/50 text-center">LA PIEDRA DE LAZARO © 2026</p>
</div>
</footer>
</body></html>

<%- include('partials/_footer') %>
